# Copy this file to .env and fill in your API key

OPENROUTER_API_KEY=your_api_key_here
# Optional: override the default model.
# OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview

# Optional: OpenRouter request metadata and endpoint overrides.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=https://github.com/jere-mie/massfinder-we
# OPENROUTER_APP_NAME=bulletin-scraper

# Optional: application defaults. CLI flags still take precedence.
# BULLETIN_SCRAPER_TARGETS=schedule,events,intentions
# BULLETIN_SCRAPER_STRATEGIES=direct,extract-merge,reviewed
# BULLETIN_SCRAPER_INPUT_MODES=images,text
# BULLETIN_SCRAPER_MODEL=google/gemini-3.1-flash-lite-preview
# BULLETIN_SCRAPER_WORKERS=4
# BULLETIN_SCRAPER_FAMILY_LIMIT=1
# BULLETIN_SCRAPER_FAMILY_FILTER=amherstburg
# BULLETIN_SCRAPER_USE_EXISTING_BULLETINS=false
# BULLETIN_SCRAPER_REFRESH_BULLETINS=false
# BULLETIN_SCRAPER_LOG_LEVEL=INFO
# BULLETIN_SCRAPER_CHURCHES_PATH=data/churches.json
# BULLETIN_SCRAPER_EVENTS_PATH=data/events.json
# BULLETIN_SCRAPER_INTENTIONS_PATH=data/intentions.json
# BULLETIN_SCRAPER_BULLETINS_DIR=bulletins
# BULLETIN_SCRAPER_BULLETIN_CACHE_PATH=bulletins/cache_index.json
# BULLETIN_SCRAPER_RUNS_DIR=runs
